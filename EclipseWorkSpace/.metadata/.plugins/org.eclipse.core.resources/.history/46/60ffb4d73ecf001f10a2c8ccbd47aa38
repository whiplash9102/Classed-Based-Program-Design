package lab5;

public class Book {
	String title;
	String author;
	int year;
	double price;
	
	Book(String title, String author, int year, double price){
		this.title = title;
		this.author = author;
		this.year = year;
		this.price = price;
	}
	
	public double discountPrice(int discount) {
		return (this.price / discount) ;
	}

}
